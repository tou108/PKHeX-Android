<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PKHeX.Android.ViewModels"
             x:Class="PKHeX.Android.Pages.BoxViewPage"
             x:DataType="vm:BoxViewModel"
             Title="ボックス"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto,Auto,*" Padding="8">

        <!-- Box Navigation Bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="48,*,48"
              BackgroundColor="#1E1E1E"
              Padding="8">

            <Button Grid.Column="0"
                    Text="◀"
                    Command="{Binding PreviousBoxCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#BB86FC"
                    FontSize="20"
                    FontAttributes="Bold"
                    BorderColor="Transparent" />

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                <Label Text="{Binding BoxName}"
                       TextColor="White"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="{Binding CurrentBox, StringFormat='{0}/{1}',
                              Converter={StaticResource BoxCountConverter},
                              ConverterParameter={Binding TotalBoxes}}"
                       TextColor="#888888"
                       FontSize="12"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Button Grid.Column="2"
                    Text="▶"
                    Command="{Binding NextBoxCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#BB86FC"
                    FontSize="20"
                    FontAttributes="Bold"
                    BorderColor="Transparent" />
        </Grid>

        <!-- Party / Box Toggle -->
        <Button Grid.Row="1"
                Text="{Binding ShowParty, Converter={StaticResource BoolToPartyLabelConverter}}"
                Command="{Binding TogglePartyViewCommand}"
                BackgroundColor="#2A2A2A"
                TextColor="#BB86FC"
                FontSize="13"
                HeightRequest="36"
                Margin="8,4" />

        <!-- Pokemon Grid -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Slots}"
                        Margin="4">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="6"
                                 HorizontalItemSpacing="4"
                                 VerticalItemSpacing="4" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:PokemonSlotViewModel">
                    <Frame BackgroundColor="{Binding SlotBackground}"
                           BorderColor="#333333"
                           CornerRadius="8"
                           Padding="4"
                           HeightRequest="80">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BoxViewModel}},
                                          Path=SelectSlotCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <!-- Shiny indicator -->
                            <Label Text="{Binding ShinyIndicator}"
                                   FontSize="10"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}" />

                            <!-- Species Name -->
                            <Label Text="{Binding DisplayName}"
                                   TextColor="White"
                                   FontSize="9"
                                   LineBreakMode="TailTruncation"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />

                            <!-- Level & Gender -->
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="2"
                                                   IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">
                                <Label Text="{Binding DisplayLevel}"
                                       TextColor="#AAAAAA"
                                       FontSize="8" />
                                <Label Text="{Binding DisplayGender}"
                                       TextColor="#88AAFF"
                                       FontSize="8" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
